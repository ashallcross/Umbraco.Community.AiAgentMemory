{
  "$schema": "appsettings-schema.json",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },
  "Umbraco": {
    "CMS": {
      "Global": {
        "Id": "158c2ff6-4270-4b8b-a830-51b0156b74da"
      },
      "Content": {
        "AllowEditInvariantFromNonDefault": true,
        "ContentVersionCleanupPolicy": {
          "EnableCleanup": true
        }
      },
      "Unattended": {
        "UpgradeUnattended": true
      },
      "Security": {
        "AllowConcurrentLogins": false
      },
      "ModelsBuilder": {
        "ModelsMode": "InMemoryAuto"
      },
      "Imaging": {
        "HMACSecretKey": "LBjuKAYn8iF9MSDk5QuKE7kOkq9g4SgE5Oe1hWz9k13Ix7LXzC27xgwIXS1AWFfdUJeXxus5EzLKcETzjXga\u002Bg=="
      }
    }
  },
  "Cogworks": {
    "AgentMemory": {
      "TopKMemories": 5,
      "MaxMemoryAgeDays": 90,
      "DigestMaxChars": 500,
      "DigestProfile": "anthropic-haiku-4-5",
      "EmbeddingProfileAlias": null,
      "EligibilityThreshold": 0.7,
      "EnabledAgents": [],
      "VectorIndex": {
        "Alias": "cogworks-agent-memory"
      }
    }
  },
  "ConnectionStrings": {
    "umbracoDbDSN": "Data Source=|DataDirectory|/Umbraco.sqlite.db;Cache=Shared;Foreign Keys=True;Pooling=True",
    "umbracoDbDSN_ProviderName": "Microsoft.Data.Sqlite"
  }
}
